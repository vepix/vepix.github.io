<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Alex Carter | Mechanical Engineer</title>
  <meta name="description" content="Mechanical engineering portfolio featuring CAD, prototyping, FEA, and product design projects." />
  <style>
    :root {
      --bg: #f5f7fa;
      --surface: #ffffff;
      --text: #111827;
      --muted: #5b6472;
      --line: #d9dee7;
      --accent: #1f6feb;
      --accent-soft: #e8f0ff;
      --shadow: 0 16px 40px rgba(17, 24, 39, 0.08);
      --radius: 22px;
      --max: 1120px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: linear-gradient(180deg, #f7f9fc 0%, #eef2f8 100%);
      color: var(--text);
      line-height: 1.6;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    .container { width: min(calc(100% - 2rem), var(--max)); margin: 0 auto; }

    .nav {
      position: sticky;
      top: 0;
      z-index: 40;
      backdrop-filter: blur(12px);
      background: rgba(245, 247, 250, 0.82);
      border-bottom: 1px solid rgba(217, 222, 231, 0.8);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.95rem 0;
      gap: 1rem;
    }

    .brand {
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .nav-links {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .nav-links a {
      color: var(--muted);
      font-size: 0.96rem;
    }

    .nav-links a:hover { color: var(--text); }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      border-radius: 999px;
      border: 1px solid transparent;
      padding: 0.9rem 1.25rem;
      font-weight: 600;
      transition: 0.2s ease;
      cursor: pointer;
    }

    .button.primary {
      background: var(--text);
      color: white;
      box-shadow: var(--shadow);
    }

    .button.primary:hover { transform: translateY(-1px); }

    .button.secondary {
      border-color: var(--line);
      background: rgba(255, 255, 255, 0.75);
      color: var(--text);
    }

    .button.secondary:hover { background: white; }

    .hero {
      padding: 4.5rem 0 3rem;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 1.5rem;
      align-items: stretch;
    }

    .hero-copy, .hero-card, .card, .project-card, .about-card, .contact-card {
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(217, 222, 231, 0.95);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .hero-copy {
      padding: 2.4rem;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--accent-soft);
      color: var(--accent);
      border-radius: 999px;
      padding: 0.45rem 0.8rem;
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    h1, h2, h3 { line-height: 1.1; margin: 0; }

    h1 {
      font-size: clamp(2.5rem, 6vw, 4.8rem);
      letter-spacing: -0.05em;
      margin-bottom: 1rem;
    }

    .hero-copy p {
      font-size: 1.05rem;
      color: var(--muted);
      max-width: 62ch;
      margin: 0 0 1.4rem;
    }

    .hero-actions {
      display: flex;
      gap: 0.9rem;
      flex-wrap: wrap;
      margin-bottom: 1.8rem;
    }

    .metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .metric {
      border-top: 1px solid var(--line);
      padding-top: 1rem;
    }

    .metric strong {
      display: block;
      font-size: 1.45rem;
      letter-spacing: -0.03em;
    }

    .metric span {
      color: var(--muted);
      font-size: 0.92rem;
    }

    .hero-card {
      padding: 1.2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .render {
      background: linear-gradient(135deg, #dde7f5, #f9fbff);
      border-radius: calc(var(--radius) - 8px);
      padding: 1rem;
      min-height: 360px;
      position: relative;
      overflow: hidden;
      border: 1px solid #e6ebf3;
    }

    .render svg {
      width: 100%;
      height: 100%;
    }

    .tag-list, .skill-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
    }

    .tag, .skill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 0.45rem 0.8rem;
      background: white;
      border: 1px solid var(--line);
      color: var(--muted);
      font-size: 0.9rem;
    }

    section {
      padding: 1.5rem 0 3rem;
    }

    .section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.4rem;
    }

    .section-head p {
      margin: 0.5rem 0 0;
      color: var(--muted);
      max-width: 58ch;
    }

    .featured {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 1.25rem;
      align-items: stretch;
    }

    .carousel {
      position: relative;
      overflow: hidden;
      border-radius: var(--radius);
      background: var(--surface);
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
      min-height: 420px;
    }

    .slides {
      display: flex;
      transition: transform 0.35s ease;
      height: 100%;
    }

    .slide {
      min-width: 100%;
      padding: 1.2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      background: linear-gradient(180deg, #f9fbff 0%, #eef3fa 100%);
    }

    .slide-visual {
      flex: 1;
      min-height: 280px;
      border-radius: 18px;
      border: 1px solid #dce3ef;
      background: white;
      display: grid;
      place-items: center;
      padding: 1rem;
    }

    .slide-caption {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .muted { color: var(--muted); }

    .carousel-controls {
      position: absolute;
      right: 1rem;
      bottom: 1rem;
      display: flex;
      gap: 0.65rem;
    }

    .icon-btn {
      width: 44px;
      height: 44px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.95);
      cursor: pointer;
      font-size: 1.1rem;
    }

    .project-card {
      padding: 1.6rem;
    }

    .project-card h3 {
      font-size: 1.7rem;
      margin-bottom: 0.7rem;
    }

    .project-card p { color: var(--muted); }

    .details {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.9rem;
      margin-top: 1.2rem;
    }

    .detail {
      background: #f9fbff;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 0.9rem;
    }

    .detail strong {
      display: block;
      margin-bottom: 0.25rem;
      font-size: 0.94rem;
    }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .card {
      padding: 1.35rem;
    }

    .card h3 { margin-bottom: 0.55rem; }
    .card p { margin: 0 0 1rem; color: var(--muted); }

    .mini-visual {
      height: 180px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: linear-gradient(135deg, #f9fbff, #edf3fb);
      margin-bottom: 1rem;
      display: grid;
      place-items: center;
      overflow: hidden;
    }

    .skill-panel {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .about-card, .contact-card {
      padding: 1.6rem;
    }

    .contact-links {
      display: flex;
      gap: 0.8rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    footer {
      padding: 0 0 3rem;
      color: var(--muted);
      font-size: 0.95rem;
    }

    @media (max-width: 980px) {
      .hero-grid,
      .featured,
      .project-grid,
      .skill-panel,
      .about-grid {
        grid-template-columns: 1fr;
      }

      .metrics,
      .details {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 680px) {
      .hero { padding-top: 3rem; }
      .hero-copy, .hero-card, .project-card, .card, .about-card, .contact-card { padding: 1.2rem; }
      .nav-inner { align-items: start; flex-direction: column; }
      .nav-links { gap: 0.75rem; }
      .metrics,
      .details { grid-template-columns: 1fr; }
      h1 { font-size: clamp(2.2rem, 12vw, 3.4rem); }
      .section-head { align-items: start; flex-direction: column; }
    }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <div class="brand">Alex Carter — Mechanical Engineer</div>
      <div class="nav-links">
        <a href="#projects">Projects</a>
        <a href="#skills">Skills</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        <a class="button secondary" href="#contact">Hire Me</a>
      </div>
    </div>
  </nav>

  <header class="hero">
